---
const { title = 'Byeolter', description = 'Building thoughtful apps, games, and AI experiences.' } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #f8fafc;
        background: #0f1020;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(255, 215, 128, 0.24), transparent 32rem),
          radial-gradient(circle at bottom right, rgba(132, 104, 255, 0.22), transparent 34rem),
          #0f1020;
      }
      a { color: inherit; }
      .wrap { width: min(960px, calc(100% - 40px)); margin: 0 auto; }
      header { padding: 28px 0; display: flex; justify-content: space-between; align-items: center; }
      .brand { font-weight: 800; letter-spacing: -0.04em; font-size: 24px; text-decoration: none; }
      nav { display: flex; gap: 18px; color: #cbd5e1; font-size: 14px; }
      nav a { text-decoration: none; }
      main { padding: 72px 0 96px; }
      .hero { max-width: 760px; }
      .star { font-size: 48px; margin-bottom: 20px; }
      h1 { font-size: clamp(52px, 9vw, 112px); line-height: 0.9; margin: 0; letter-spacing: -0.08em; }
      .lead { margin-top: 28px; font-size: clamp(20px, 3vw, 30px); line-height: 1.35; color: #dbeafe; max-width: 680px; }
      .desc { margin-top: 18px; color: #94a3b8; font-size: 17px; line-height: 1.7; max-width: 640px; }
      .cards { margin-top: 56px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
      .card { border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.06); border-radius: 24px; padding: 24px; backdrop-filter: blur(12px); }
      .card h2 { margin: 0 0 10px; font-size: 22px; }
      .card p { margin: 0; color: #cbd5e1; line-height: 1.6; }
      footer { padding: 32px 0; border-top: 1px solid rgba(255,255,255,0.1); color: #94a3b8; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <a class="brand" href="/">★ Byeolter</a>
        <nav>
          <a href="/apps/">Apps</a>
          <a href="/privacy/">Privacy</a>
          <a href="mailto:contact@byeolter.com">Contact</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer>© {new Date().getFullYear()} Byeolter. All rights reserved.</footer>
    </div>
  </body>
</html>
