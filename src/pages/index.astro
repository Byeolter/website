---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>
  <section class="hero">
    <div class="star">⭐</div>
    <h1>Byeolter</h1>
    <p class="lead">Apps, games, and AI experiences with a little bit of magic.</p>
    <p class="desc">
      Byeolter is an independent studio building thoughtful digital experiences —
      from mobile apps to playful games and AI-powered tools.
    </p>
  </section>

  <section class="cards">
    <article class="card">
      <h2>별보는 고양이</h2>
      <p>A magical fortune app coming soon.</p>
    </article>
    <article class="card">
      <h2>Games</h2>
      <p>Small, playful experiments and interactive worlds.</p>
    </article>
    <article class="card">
      <h2>AI</h2>
      <p>Useful AI experiences made for everyday life.</p>
    </article>
  </section>
</BaseLayout>
