---
// Byeolter Privacy Policy Page
---
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="Byeolter Privacy Policy — your privacy matters.">
<title>Privacy Policy | Byeolter</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/galmuri/dist/galmuri.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" rel="stylesheet">
<style>
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  img{image-rendering:pixelated}
  ::selection{background:#ffd23f;color:#0a0a1f}
  @keyframes twpix{0%,100%{opacity:.35}50%{opacity:1}}
  @media (max-width:760px){
    [data-nav-desktop]{display:none !important}
    [data-nav-burger]{display:flex !important}
  }
</style>
</head>
<body>
<div style="position:relative;min-height:100vh;background:radial-gradient(120% 70% at 50% -10%, #1a1140 0%, rgba(26,17,64,0) 55%), #0a0a1f;color:#eaf0ff;font-family:'Pretendard Variable',Pretendard,system-ui,sans-serif">

  <div id="sky" style="position:fixed;inset:0;overflow:hidden;pointer-events:none;z-index:1"></div>

  <div style="position:relative;z-index:5">

    <!-- NAV -->
    <nav style="position:sticky;top:0;z-index:40;display:flex;align-items:center;justify-content:space-between;gap:14px;padding:16px clamp(16px,4vw,40px);border-bottom:3px solid #000;background:#0d0d28;box-shadow:0 3px 0 #ffd23f">
      <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:#eaf0ff">
        <img src="/assets/star.png" alt="Byeolter star" width="26" height="26" style="display:block">
        <span style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:13px;color:#ffd23f;letter-spacing:1px">BYEOLTER</span>
      </a>
      <div style="display:flex;align-items:center;gap:26px" data-nav-desktop="">
        <a href="/apps/" style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:9px;color:#4fe0d8;text-decoration:none">APPS</a>
        <a href="/games/" style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:9px;color:#ff5db1;text-decoration:none">GAMES</a>
        <a href="/#contact" style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:9px;color:#9bf24a;text-decoration:none">CONTACT</a>
      </div>
      <button id="btn-menu" aria-label="Menu" style="display:none;background:#ff5db1;border:3px solid #000;width:42px;height:38px;cursor:pointer;box-shadow:3px 3px 0 #000;align-items:center;justify-content:center;flex-direction:column;gap:4px" data-nav-burger="">
        <span style="width:18px;height:3px;background:#0a0a1f;display:block"></span>
        <span style="width:18px;height:3px;background:#0a0a1f;display:block"></span>
        <span style="width:18px;height:3px;background:#0a0a1f;display:block"></span>
      </button>
    </nav>
    <div id="mobile-menu" style="position:sticky;top:71px;z-index:39;display:none;flex-direction:column;background:#0d0d28;border-bottom:3px solid #000;box-shadow:0 10px 0 rgba(0,0,0,.35)">
      <a href="/apps/" onclick="document.getElementById('mobile-menu').style.display='none'" style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:10px;color:#4fe0d8;text-decoration:none;padding:16px 24px;border-bottom:2px solid #1d1d44">APPS</a>
      <a href="/games/" onclick="document.getElementById('mobile-menu').style.display='none'" style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:10px;color:#ff5db1;text-decoration:none;padding:16px 24px;border-bottom:2px solid #1d1d44">GAMES</a>
      <a href="/#contact" onclick="document.getElementById('mobile-menu').style.display='none'" style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:10px;color:#9bf24a;text-decoration:none;padding:16px 24px">CONTACT</a>
    </div>

    <main style="max-width:800px;margin:0 auto;padding:clamp(40px,7vw,76px) clamp(16px,4vw,28px) clamp(48px,8vw,90px)">

      <!-- HERO -->
      <header style="text-align:center;margin-bottom:clamp(34px,6vw,52px)">
        <img src="/assets/star.png" alt="" width="56" height="56" style="display:block;margin:0 auto 22px;filter:drop-shadow(0 0 14px rgba(255,210,63,.45))">
        <h1 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(24px,6vw,46px);line-height:1.22;margin:0;color:#ffd23f;text-shadow:4px 4px 0 #ff5db1;letter-spacing:1px">PRIVACY POLICY</h1>
        <p style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(10px,2.2vw,12px);color:#4fe0d8;letter-spacing:1px;margin:22px 0 0">Your privacy matters.</p>
        <p style="font-size:clamp(16px,2.4vw,19px);line-height:1.7;color:#cdd6ff;max-width:54ch;margin:18px auto 0">We believe great software should respect your privacy just as much as your experience.</p>
        <div style="display:inline-flex;align-items:center;gap:10px;margin-top:28px;background:#0e1030;border:3px solid #000;box-shadow:4px 4px 0 rgba(0,0,0,.4);padding:10px 16px">
          <span style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:8px;color:#6a73b8;letter-spacing:1px">LAST UPDATED</span>
          <span style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:9px;color:#9bf24a;letter-spacing:1px">JUNE 25, 2026</span>
        </div>
      </header>

      <!-- NPC SPEECH BUBBLE -->
      <div style="display:flex;justify-content:center;margin-bottom:clamp(40px,7vw,64px)">
        <div style="display:flex;align-items:center;gap:14px;background:#12153a;border:3px solid #000;box-shadow:5px 5px 0 rgba(0,0,0,.4);padding:16px 20px;position:relative;max-width:520px">
          <div style="position:absolute;left:34px;bottom:-12px;width:18px;height:12px;background:#12153a;border-right:3px solid #000;border-bottom:3px solid #000;transform:skewX(-18deg)"></div>
          <img src="/assets/star.png" alt="" width="34" height="34" style="display:block;flex-shrink:0">
          <p style="margin:0;font-size:clamp(15px,2.2vw,18px);line-height:1.55;color:#eaf0ff">&ldquo;Your data belongs to you.&rdquo;<br><span style="font-size:.82em;color:#8089c0">— a friendly note from the BYEOLTER crew</span></p>
        </div>
      </div>

      <!-- SECTIONS -->
      <div style="display:flex;flex-direction:column;gap:clamp(22px,3.5vw,30px)">

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px)">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">Introduction</h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0">BYEOLTER is a small indie studio in Seoul making apps and games &mdash; little pieces of software we hope feel like magic. This policy explains, in plain language, what information our apps, games, and website handle, why, and the choices you have. Most of what we make works without an account and without asking for personal data at all.</p>
        </section>

        <div style="text-align:center"><img src="/assets/star.png" alt="" width="18" height="18" style="display:inline-block;opacity:.7"></div>

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px)">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">Information We Collect</h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0 0 16px">We collect as little as possible. Depending on how you use our software, this may include:</p>
          <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:12px">
            <li style="display:flex;gap:12px;font-size:clamp(15px,2.2vw,18px);line-height:1.7;color:#cdd6ff"><span style="color:#4fe0d8;flex-shrink:0">&#9656;</span><span><strong style="color:#eaf0ff">On-device data.</strong> Your game saves, settings, and preferences stay on your device. We don&rsquo;t upload them.</span></li>
            <li style="display:flex;gap:12px;font-size:clamp(15px,2.2vw,18px);line-height:1.7;color:#cdd6ff"><span style="color:#4fe0d8;flex-shrink:0">&#9656;</span><span><strong style="color:#eaf0ff">Crash &amp; diagnostic data.</strong> If something breaks, anonymous crash reports help us fix it. These contain no personal identity.</span></li>
            <li style="display:flex;gap:12px;font-size:clamp(15px,2.2vw,18px);line-height:1.7;color:#cdd6ff"><span style="color:#4fe0d8;flex-shrink:0">&#9656;</span><span><strong style="color:#eaf0ff">Messages you send us.</strong> If you email support, we keep your message and address only to reply.</span></li>
          </ul>
        </section>

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px)">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">How We Use Information</h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0">We use the little data we have only to keep our software running smoothly &mdash; fixing crashes, understanding which features are loved, and replying when you reach out. We never sell your data, and we never use it to build advertising profiles about you.</p>
        </section>

        <div style="text-align:center"><img src="/assets/star.png" alt="" width="18" height="18" style="display:inline-block;opacity:.7"></div>

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px)">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">Third-party Services</h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0">Some of our apps rely on trusted services to operate &mdash; for example <a href="https://policies.google.com/privacy" target="_blank" rel="noopener" style="color:#4fe0d8;text-decoration:underline;text-underline-offset:3px">Google Play Services</a> for distribution and crash reporting. These providers handle data under their own privacy policies. We choose partners that respect privacy and share only what is strictly needed for the service to work.</p>
        </section>

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px)">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">Cookies <span style="color:#6a73b8;font-size:.8em">(website only)</span></h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0">This website uses only the essential cookies needed to remember basic preferences. We don&rsquo;t use tracking or advertising cookies. Our apps and games don&rsquo;t use cookies at all.</p>
        </section>

        <div style="text-align:center"><img src="/assets/star.png" alt="" width="18" height="18" style="display:inline-block;opacity:.7"></div>

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px)">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">Data Retention</h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0">We keep data only as long as it serves a clear purpose. Crash and diagnostic data is retained briefly, then discarded. Support emails are kept only as long as needed to help you. You can ask us to delete anything we hold about you at any time.</p>
        </section>

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px)">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">Your Rights</h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0 0 16px">You are always in control. You have the right to:</p>
          <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:12px">
            <li style="display:flex;gap:12px;font-size:clamp(15px,2.2vw,18px);line-height:1.7;color:#cdd6ff"><span style="color:#9bf24a;flex-shrink:0">&#9656;</span><span>Ask what data we hold about you</span></li>
            <li style="display:flex;gap:12px;font-size:clamp(15px,2.2vw,18px);line-height:1.7;color:#cdd6ff"><span style="color:#9bf24a;flex-shrink:0">&#9656;</span><span>Request a correction or deletion</span></li>
            <li style="display:flex;gap:12px;font-size:clamp(15px,2.2vw,18px);line-height:1.7;color:#cdd6ff"><span style="color:#9bf24a;flex-shrink:0">&#9656;</span><span>Withdraw consent for optional data collection</span></li>
          </ul>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:16px 0 0">Just send us a note and we&rsquo;ll take care of it.</p>
        </section>

        <div style="text-align:center"><img src="/assets/star.png" alt="" width="18" height="18" style="display:inline-block;opacity:.7"></div>

        <section style="background:#0e1030;border:3px solid #000;box-shadow:0 0 0 3px #1d1d44, 0 14px 34px rgba(0,0,0,.4);padding:clamp(22px,4vw,34px);text-align:center">
          <h2 style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(13px,2.6vw,17px);line-height:1.5;color:#ffd23f;margin:0 0 18px">Contact Information</h2>
          <p style="font-size:clamp(15px,2.2vw,18px);line-height:1.8;color:#cdd6ff;margin:0 0 22px">Questions about your privacy? We&rsquo;d genuinely love to hear from you.</p>
          <a href="mailto:contact@byeolter.com" style="display:inline-flex;align-items:center;gap:12px;font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(10px,2.2vw,13px);color:#0a0a1f;background:#4fe0d8;text-decoration:none;padding:16px 22px;border:3px solid #000;box-shadow:5px 5px 0 #000">
            <img src="/assets/star.png" width="20" height="20" alt="">contact@byeolter.com
          </a>
        </section>

      </div>

      <!-- BOTTOM MESSAGE -->
      <div style="text-align:center;margin-top:clamp(48px,8vw,80px)">
        <img src="/assets/star.png" alt="" width="40" height="40" style="display:block;margin:0 auto 22px;filter:drop-shadow(0 0 12px rgba(255,210,63,.4))">
        <p style="font-family:'Press Start 2P','Galmuri11',monospace;font-size:clamp(11px,2.4vw,14px);line-height:1.9;color:#ffd23f;margin:0">Made with care.</p>
        <p style="font-size:clamp(15px,2.3vw,18px);line-height:1.85;color:#cdd6ff;max-width:46ch;margin:18px auto 0">Designed with respect for your privacy. Thank you for visiting our little corner of the universe.</p>
        <p style="font-size:clamp(14px,2.2vw,17px);line-height:1.7;color:#8089c0;margin:14px 0 0">Keep exploring. <span style="color:#9bf24a">&#9733;</span></p>
      </div>

    </main>

    <!-- FOOTER -->
    <footer style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;padding:18px clamp(16px,4vw,40px);border-top:3px solid #000;background:#0d0d28;font-family:'Press Start 2P','Galmuri11',monospace;font-size:8px;color:#6a73b8">
      <span style="color:#ffd23f">&copy; 2026 BYEOLTER</span>
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:24px">
        <a href="/privacy/" style="color:#4fe0d8;text-decoration:none;border-bottom:2px solid #4fe0d8;padding-bottom:3px">PRIVACY</a>
        <a href="mailto:contact@byeolter.com" style="color:#ff5db1;text-decoration:none">CONTACT</a>
        <a href="https://play.google.com/store/apps/details?id=com.starterkim.widgetbuddy&hl=ko" target="_blank" rel="noopener" style="color:#9bf24a;text-decoration:none">GOOGLE PLAY</a>
      </div>
    </footer>

  </div>
</div>

<script>
// Sky stars (softer palette, lower density)
(function() {
  const sky = document.getElementById('sky');
  const cols = ['#ffffff','#aeb9ff','#ffd23f','#4fe0d8'];
  for (let i = 0; i < 46; i++) {
    const d = document.createElement('div');
    const size = Math.random() < 0.75 ? 2 : 3;
    const dur = (3 + Math.random() * 4).toFixed(2);
    const delay = (Math.random() * 5).toFixed(2);
    const baseOp = (0.4 + Math.random() * 0.4).toFixed(2);
    d.style.cssText = `position:absolute;left:${(Math.random()*100).toFixed(2)}%;top:${(Math.random()*100).toFixed(2)}%;width:${size}px;height:${size}px;background:${cols[(Math.random()*cols.length)|0]};image-rendering:pixelated;opacity:${baseOp};animation:twpix ${dur}s ease-in-out ${delay}s infinite`;
    sky.appendChild(d);
  }
})();

// Mobile nav
document.getElementById('btn-menu').addEventListener('click', () => {
  const m = document.getElementById('mobile-menu');
  m.style.display = m.style.display === 'flex' ? 'none' : 'flex';
});
</script>
</body>
</html>
